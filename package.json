{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "sonar": "docker compose --env-file .env -f docker-compose.ci.yml run --rm sonar-scanner",
    "docker:build": "docker compose build frontend",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "sonar:all": "npm run sonar && sh -c 'cd ../cicd-tasklist-backend && npm run sonar'",
    "trivy": "npm run trivy:scan",
    "trivy:build": "docker compose build frontend",
    "trivy:scan": "mkdir -p reports && docker compose -f docker-compose.ci.yml run --rm trivy",
    "trivy:sbom": "mkdir -p reports && docker run --rm -v /var/run/docker.sock:/var/run/docker.sock -v \"$(pwd)/reports:/reports\" -v cicd-tasklist-frontend_trivy-cache:/root/.cache/trivy aquasec/trivy:latest image --format cyclonedx --output /reports/sbom.cdx.json efrei-pro-pipepline-tp4-frontend:latest",
    "trivy:ci": "npm run trivy:build && npm run trivy:scan && npm run trivy:sbom",
    "docker:tag": "docker tag efrei-pro-pipepline-tp4-frontend:latest liamor2/efrei-pro-pipepline-tp4-frontend:latest",
    "docker:push": "npm run docker:tag && docker push liamor2/efrei-pro-pipepline-tp4-frontend:latest",
    "sonar:ci": "docker compose -f docker-compose.ci.yml run --rm sonar-scanner",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "biome ci ."
  },
  "dependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
